{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["./packages/core/src/*"],
      "@react/*": ["./packages/react/src/*"],
      "@gemwallet/*": ["./packages/adapters/gemwallet/src/*"],
      "@xaman/*": ["./packages/adapters/xaman/src/*"],
      "@crossmark/*": ["./packages/adapters/crossmark/src/*"]
    }
  }
}
