{
  "name": "@trustauthy/xrpl-wallet-connect",
  "version": "0.1.0",
  "license": "MIT",
  "workspaces": [
    "packages/core",
    "packages/react",
    "packages/adapters/*"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./react": {
      "types": "./dist/src/react.d.ts",
      "default": "./dist/src/react.js"
    },
    "./adapters": {
      "types": "./dist/src/adapters.d.ts",
      "default": "./dist/src/adapters.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "vp check",
    "test": "vp test",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@crossmarkio/sdk": "^0.4.0",
    "@gemwallet/api": "^3.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xumm-oauth2-pkce": "^2.8.7"
  },
  "devDependencies": {
    "@oxfmt/binding-darwin-arm64": "^0.42.0",
    "@oxlint/binding-darwin-arm64": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "@voidzero-dev/vite-plus-darwin-arm64": "^0.1.14",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vite-plus": "^0.1.12",
    "vitest": "^3.0.8"
  }
}
